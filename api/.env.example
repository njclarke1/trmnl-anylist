# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.

# ── AnyList credentials ───────────────────────────────────────────────────────
ANYLIST_EMAIL=your-anylist-email@example.com
ANYLIST_PASSWORD=your-anylist-password

# ── API protection ────────────────────────────────────────────────────────────
# Generate a strong random token, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This value must match what you put in TRMNL's custom field "API Token".
API_TOKEN=replace-with-a-strong-random-token

# ── Optional overrides ────────────────────────────────────────────────────────
# Default list name if ?name= query param is not provided
ANYLIST_LIST_NAME=Groceries

# Port (default: 3457)
# PORT=3457
